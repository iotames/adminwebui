{
  "name": "admerp-webui",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node -e \"process.env.VITE_BASE_API_URL || (console.error('[错误] 生产构建必须设置环境变量: VITE_BASE_API_URL'); process.exit(1))\" && vite build",
    "preview": "vite preview",
    "mock:init": "npx msw init mock/public --save"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw"
    ]
  },
  "devDependencies": {
    "msw": "^2.7.3",
    "puppeteer": "^25.1.0",
    "typescript": "^5.7.3",
    "vite": "^6.3.2"
  },
  "dependencies": {
    "zustand": "^5.0.3"
  },
  "msw": {
    "workerDirectory": [
      "mock/public"
    ]
  }
}